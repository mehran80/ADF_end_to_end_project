{
	"name": "on_prem_sink_parquet_dataset",
	"properties": {
		"linkedServiceName": {
			"referenceName": "airline_azure_linked_service_onprem",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"p_file_name": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().p_file_name",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat('onprem/', formatDateTime(utcNow(),'yyyy/MM/dd'))",
					"type": "Expression"
				},
				"fileSystem": "bronze"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}